# ============================================
# API CONFIGURATION
# ============================================
# Backend API base URL
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ============================================
# WEBSOCKET CONFIGURATION
# ============================================
# WebSocket URL for real-time notifications
VITE_WS_URL=ws://localhost:8080/api/v1/notifications/ws

# ============================================
# ENVIRONMENT
# ============================================
# Options: development, production
VITE_ENVIRONMENT=development

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
# Enable/disable features for testing
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_ANALYTICS=true

# ============================================
# GOOGLE ANALYTICS 4 (GA4) CONFIGURATION
# ============================================
# Get your Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX (starts with "G-")
# Leave empty or commented out to disable analytics
# Note: Analytics only runs in production mode (npm run build)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# SENTRY CONFIGURATION (Optional - for error tracking)
# ============================================
# Get your DSN from: https://sentry.io/settings/projects/
# Sentry only runs in production mode (npm run build)
# Features: Error tracking, Session Replay, Performance Monitoring
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# GOOGLE CALENDAR INTEGRATION (Optional)
# ============================================
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 credentials for a Web application
# Add authorized redirect URI: http://localhost:8080/api/v1/calendar/google/callback
# Enable Google Calendar API in your Google Cloud project
# VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Copy this file to .env: cp .env.example .env
# 2. All variables must start with VITE_ to be exposed to the app
# 3. Never commit .env file to git (it's in .gitignore)
# 4. Restart dev server after changing .env
# 5. For production, update VITE_API_BASE_URL to your production API URL
